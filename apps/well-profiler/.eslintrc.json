{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "plugin:react/recommended",
    "airbnb",
    "plugin:import/errors",
    "plugin:import/warnings",
    "plugin:import/typescript",
    "plugin:prettier/recommended",
    "next",
    "next/core-web-vitals"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": ["react", "@typescript-eslint", "react-hooks", "prettier"],
  "rules": {
    "linebreak-style": ["error", "unix"], // enforce consistent linebreak style
    "max-len": [
      "error",
      {
        "code": 80,
        "ignoreUrls": true,
        "ignoreStrings": true,
        "ignoreTemplateLiterals": true,
        "ignoreComments": true
      }
    ], // limit lines to 80 characters
    "no-unused-vars": "warn",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_" }
    ],
    "prefer-promise-reject-errors": ["warn"], // require using Error objects as Promise rejection reasons
    "react/jsx-filename-extension": [
      "warn",
      { "extensions": [".jsx", ".tsx"] }
    ], // allow jsx syntax in .jsx and .tsx files
    "react/prefer-stateless-function": ["error"], // enforce stateless React Components to be written as a pure function
    "react/prop-types": ["off"], // turn off prop-types as we are using TypeScript for type checking
    "object-curly-newline": ["error", { "consistent": true }], // enforce consistent line breaks inside braces
    "no-return-assign": ["error", "always"], // disallow assignment operators in return statements
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "never",
        "jsx": "never",
        "ts": "never",
        "tsx": "never"
      }
    ], // ensure consistent use of file extension within the import path
    "no-use-before-define": "error", // disallow the use of variables before they are defined
    "@typescript-eslint/no-use-before-define": ["error"], // disallow the use of variables before they are defined
    // use Prettier for code formatting
    "prettier/prettier": [
      "error",
      {
        "endOfLine": "auto"
      }
    ],
    "react-hooks/rules-of-hooks": "error", // enforce the rules of Hooks
    "react-hooks/exhaustive-deps": "warn", // enforce the exhaustive dependencies style for useEffect
    "react/require-default-props": ["off"], // turn off as we are using TypeScript for optional props
    "react/no-array-index-key": ["error"], // make using array index as key an error
    "no-undef": ["error"], // make undefined variables an error
    "camelcase": ["error"], // enforce camelcase naming convention
    "prefer-template": ["error"], // suggest using template literals instead of string concatenation
    "jsx-a11y/no-static-element-interactions": ["error"], // make interactive elements accessible
    "jsx-a11y/click-events-have-key-events": ["error"], // enforce that elements with onClick also have a key event listener
    "react/jsx-props-no-spreading": ["warn"], // disallow spreading props
    "no-plusplus": ["error", { "allowForLoopAfterthoughts": true }], // disallow the unary operators ++ and --
    "radix": ["error", "as-needed"], // enforce the radix parameter of parseInt
    "no-explicit-any": "off",
    "@typescript-eslint/no-unsafe-call": "warn"
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".jsx", ".ts", ".tsx"]
      }
    }
  }
}
