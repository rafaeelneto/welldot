{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es5",
    "module": "esnext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "./src/*",
    "src/components/types",
    ".next/types/**/*.ts"
, "styles"  ],
  "exclude": [
    "node_modules/*"
  ],
  "noImplicitAny": false,
  "strictNullChecks": true,
  "noImplicitThis": true,
  "alwaysStrict": true
}
