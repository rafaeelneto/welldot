{
  "name": "@welldot/render",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/main.css",
    "./styles/main.css": "./src/styles/main.css"
  },
  "files": ["dist", "src/styles"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@welldot/core": "workspace:*",
    "@welldot/utils": "workspace:*",
    "defu": "^6.1.4"
  },
  "peerDependencies": {
    "d3": "^7.0.0",
    "d3-tip": "^0.9.1",
    "textures": "^1.2.3"
  },
  "devDependencies": {
    "@welldot/lint": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3",
    "@types/d3": "^7.4.3",
    "@types/d3-tip": "^3.5.8",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
