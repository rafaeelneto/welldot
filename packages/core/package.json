{
  "name": "@welldot/core",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript types, Zod validators, and serialization utilities for the .well open format — a JSON standard for water well data.",
  "keywords": [
    "well",
    "water-well",
    "hydrogeology",
    "geoscience",
    "borehole",
    "lithology",
    "schema",
    "zod",
    "typescript",
    "open-data"
  ],
  "author": {
    "name": "Rafael Neto",
    "email": "rafaelneto.g@gmail.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/rafaeelneto/well-profiler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaeelneto/well-profiler.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/rafaeelneto/well-profiler/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "well-specifications.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@welldot/lint": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
